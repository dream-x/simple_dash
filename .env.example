# Simple Dash environment template.
# Copy to .env and edit for your network:
#   cp .env.example .env

# Local static server port used by `just dev` / `just serve` and Docker host mapping.
HTTP_PORT=8080

# Container internal port for Docker. Usually keep 8080.
PORT=8080

# Comma-separated CIDR targets. Leave empty to use dashboard_config.local.json/dashboard_config.json.
SUBNETS=192.168.1.0/24

# Watch interval in seconds for `just watch`, `just dev`, and Docker.
SCAN_INTERVAL=60

# Port discovery: none scans configured/PORTS only; common loads ports_catalog.json.
DISCOVER_PORTS=common

# Optional explicit extra ports/ranges, e.g. 8000-9000,32400.
PORTS=

# Host discovery: none, arp, icmp, arp,icmp.
HOST_DISCOVERY=arp

# Concurrency/timeouts. Lower these if your router/network gets noisy.
CONCURRENCY=64
PORT_CONCURRENCY=512
PORT_TIMEOUT=0.35
SERVICE_TIMEOUT=1.2
DNS_TIMEOUT=0.5
NETBIOS_TIMEOUT=0.45
ARP_TIMEOUT=0.4
DISCOVERY_CONCURRENCY=128
DISCOVERY_TIMEOUT=0.6

# Paths / tooling.
PYTHON=python3
OUTPUT_DIR=.
PORTS_CATALOG=ports_catalog.json
SNAPSHOT_OUTPUT=dashboard_overrides.json
COMPOSE="docker compose"

# Optional: force a specific config. Empty means auto-use dashboard_config.local.json if present,
# otherwise dashboard_config.json.
CONFIG=

# Extra raw CLI args appended to generate_dashboard.py, e.g. --service-timeout 2
EXTRA_ARGS=
